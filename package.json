    "test:e2e:critical": "npm run test:e2e:critical:prod",
    "test:e2e:critical:dev": "E2E_SCOPE=critical E2E_BROWSER_MATRIX=gate tsx scripts/run-e2e-with-server.ts",
    "test:e2e:critical:prod": "npm run build && E2E_SCOPE=critical E2E_BROWSER_MATRIX=gate tsx scripts/run-e2e-with-prod-server.ts",
    "test:e2e:full": "E2E_SCOPE=full E2E_BROWSER_MATRIX=gate tsx scripts/run-e2e-with-server.ts",
    "test:e2e:nightly": "E2E_SCOPE=full E2E_BROWSER_MATRIX=nightly playwright test",
    "check:e2e:perf": "tsx scripts/check-e2e-perf-gate.ts",
    "check:hardening-rollout": "tsx scripts/check-hardening-rollout.ts",
    "db:apply:workspace-counters": "tsx scripts/apply-workspace-counter-migration.ts",
    "db:check:workspace-counters": "tsx scripts/apply-workspace-counter-migration.ts --check-only",
    "check:stability-env": "tsx scripts/check-stability-env.ts",
    "check:stability-release": "tsx scripts/run-stability-release-gate.ts",
    "run:load-suite": "tsx scripts/run-load-suite.ts",
    "check:capacity-audit": "tsx scripts/check-capacity-audit.ts",
    "check:production-rollout": "tsx scripts/check-production-rollout-readiness.ts",
    "check:1m-readiness": "tsx scripts/check-1m-readiness.ts",
    "test:release-gate": "npm run lint -- . --ext .ts,.tsx,.js,.jsx && npm run typecheck && npm run check:deps:audit && npm run check:deps:lockfile && npm run check:db:migration-journal && npm run check:db:replay-env && npm run check:db:remigration-replay && npm run test:unit && npm run check:scroll-contract && npm run check:query-key-contract && npm run check:theme-contract && npm run check:page-contract && npm run check:force-dynamic-allowlist && npm run check:runtime-boundaries && npm run check:api-versioning-contract && npm run check:api-envelope-contract && npm run check:hub-canonical-contract && npm run check:review-guardrails && npm run check:engineering-standards && npm run test:e2e:critical:prod && npm run check:e2e:perf && npm run check:route-baseline-regression && npm run check:hardening-rollout"
  },
