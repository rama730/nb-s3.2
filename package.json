    "check:deps:audit": "npm audit --omit=dev --audit-level=high",
    "check:deps:lockfile": "bash scripts/check-lockfile-drift.sh",
    "check:review-guardrails": "bash scripts/check-review-guardrails.sh",
    "check:canonical-logic-contract": "tsx scripts/check-canonical-logic-contract.ts",
