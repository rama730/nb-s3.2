    "check:e2e:perf": "tsx scripts/check-e2e-perf-gate.ts",
    "check:hardening-rollout": "tsx scripts/check-hardening-rollout.ts",
    "test:release-gate": "npm run typecheck && npm run check:deps:audit && npm run check:deps:lockfile && npm run check:db:migration-journal && npm run check:db:replay-env && npm run check:db:remigration-replay && npm run test:unit && npm run check:scroll-contract && npm run check:query-key-contract && npm run check:theme-contract && npm run check:page-contract && npm run check:force-dynamic-allowlist && npm run check:api-versioning-contract && npm run check:api-envelope-contract && npm run check:hub-canonical-contract && npm run check:review-guardrails && npm run test:e2e:critical:prod && npm run check:e2e:perf && npm run check:route-baseline-regression && npm run check:hardening-rollout"
  },
